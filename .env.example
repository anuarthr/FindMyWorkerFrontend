# FindMyWorker Frontend
# Host puro del backend (sin /api, sin slash final). El frontend deriva la
# URL REST (`${base}/api/`) y el WebSocket (`ws(s)://host`) desde aquí.
VITE_API_BASE_URL=http://localhost:8000

# WebSocket opcional: por defecto se deriva del API base (http→ws / https→wss).
# VITE_WS_URL=ws://localhost:8000

# VITE_API_BASE_URL=https://findmyworker-api.onrender.com
# VITE_WS_URL=wss://findmyworker-api.onrender.com

# Legacy / Backwards-compat (deprecated) 
# VITE_API_URL=http://127.0.0.1:8000/api
